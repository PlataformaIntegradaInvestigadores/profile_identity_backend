SECRET_KEY=replace-me
JWT_SIGNING_KEY=replace-with-monolith-jwt-signing-key
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_COOKIE_NAME=centinela_refresh
JWT_REFRESH_COOKIE_PATH=/api
JWT_REFRESH_COOKIE_SECURE=False
JWT_REFRESH_COOKIE_SAMESITE=Lax
DEBUG=True
DB_NAME=profile_identity
DB_USER=profile_identity
DB_PASSWORD=profile_identity
DB_HOST=profile-identity-db
DB_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:8082,http://127.0.0.1:8082
CORS_ALLOW_CREDENTIALS=True
LEGACY_SYNC_BASE_URL=http://host.docker.internal:8000
LEGACY_SYNC_TOKEN=replace-with-shared-internal-token
LEGACY_SYNC_ENABLED=True
LEGACY_SYNC_RETRY_DELAY_MINUTES=5
USE_SQLITE_FOR_TESTS=False
